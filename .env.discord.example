# Copy this file to .env.discord and fill in the real values.
# Never commit the real .env.discord file.

DISCORD_BOT_TOKEN=replace-with-discord-bot-token

# Required. Comma-separated Discord user IDs allowed to control this local agent.
DISCORD_ALLOWED_USER_IDS=123456789012345678

# Optional but recommended. Empty means any channel visible to the bot.
DISCORD_ALLOWED_CHANNEL_IDS=123456789012345678

# Optional. Defaults to the repository root detected from this script.
FLOW_AGENT_REPO=/mnt/d/TEST_Making_Video/semi_all/flow
FLOW_DISCORD_PREFIX=!flow

# Enable natural-language Codex tasks. Authorized Discord users can cause local edits.
FLOW_AGENT_ALLOW_CODEX=1
FLOW_AGENT_CODEX_TIMEOUT_SECONDS=3600
FLOW_AGENT_COMMAND_TIMEOUT_SECONDS=600
FLOW_AGENT_REQUIRE_BRANCH=main
