  {
    "name": "M1DC_INDEX",
    "type": "shot_formula",
    "item_col": "item_id",
    "value_col": "value",
    "group_by": ["product", "root_lot_id", "lot_id", "wafer_id", "step_id", "step_seq", "shot_x", "shot_y"],
    "item_map": {
      "R": "Rc",
      "N": "Vth_n",
      "P": "Vth_p"
    },
    "expr": "abs(R) + abs(N - P)",
    "agg": "mean",
    "filter": "step_id == 'ETA100010'",
    "no": 40,
    "cat": "DC",
    "rawitem_id": "Rc/Vth_n/Vth_p",
    "alias": "M1DC",
    "alias_form": "fixed4",
    "report_order": 40,
    "y_axis": "linear",
    "spec": "both",
    "use": true,
    "spec_order": 40,
    "report_variant": "selected_pt_review",
    "point_mode": "selected_pt",
    "report_enabled": true,
    "point_selector": {
      "mode": "named_points",
      "points": [
        "center",
        "edge_left",
        "edge_right"
      ]
    },
    "report_audience": "external",
    "tracker_attach": false
  },
  {
    "name": "IOFF_INDEX",
    "type": "shot_formula",
    "item_col": "item_id",
    "value_col": "value",
    "group_by": ["product", "root_lot_id", "lot_id", "wafer_id", "step_id", "step_seq", "shot_x", "shot_y"],
    "item_map": {
      "IN": "Ioff_n",
      "IP": "Ioff_p",
      "LK": "lkg"
    },
    "expr": "abs(IN) + abs(IP) + 0.1 * abs(LK)",
    "agg": "mean",
    "filter": "step_id == 'ETA100010'",
    "no": 50,
    "cat": "LEAKAGE",
    "rawitem_id": "Ioff_n/Ioff_p/lkg",
    "alias": "Ioff_mix",
    "alias_form": "sci3",
    "report_order": 50,
    "y_axis": "log10",
    "spec": "usl",
    "use": true,
    "spec_order": 50,
    "report_variant": "selected_pt_review",
    "point_mode": "selected_pt",
    "report_enabled": true,
    "point_selector": {
      "mode": "named_points",
      "points": [
        "center"
      ]
    },
    "report_audience": "external",
    "tracker_attach": false
  }
]
